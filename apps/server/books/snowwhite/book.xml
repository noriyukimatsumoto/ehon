<?xml version="1.0" encoding="UTF-8"?>
<ehon>
  <page>
    <text duration="3">
      <ja>むかしむかし、ゆきのように しろい はだの</ja>
      <en>Once upon a time, there was a princess</en>
    </text>
    <text duration="3">
      <ja>うつくしい おひめさまが いました。</ja>
      <en>with skin as white as snow.</en>
    </text>
    <image>scene1.png</image>
  </page>
  <page>
    <text duration="3">
      <ja>いじわるな じょおうが まほうの かがみに</ja>
      <en>An evil queen asked her magic mirror,</en>
    </text>
    <text duration="3">
      <ja>「せかいで いちばん うつくしいのは だれ？」と ききました。</ja>
      <en>"Who is the fairest of them all?"</en>
    </text>
    <image>scene2.png</image>
  </page>
  <page>
    <text duration="3">
      <ja>しらゆきひめは もりの こびとたちの いえに</ja>
      <en>Snow White fled to the cottage</en>
    </text>
    <text duration="3">
      <ja>にげこみました。</ja>
      <en>of seven dwarfs in the forest.</en>
    </text>
    <image>scene3.png</image>
  </page>
  <page>
    <text duration="2">
      <ja>じょおうは しらゆきひめに</ja>
      <en>The evil queen gave Snow White</en>
    </text>
    <text duration="3">
      <ja>どくのりんごを たべさせました。</ja>
      <en>a poisoned apple to eat.</en>
    </text>
    <image>scene4.png</image>
  </page>
  <page>
    <text duration="3">
      <ja>しらゆきひめは りんごを たべると</ja>
      <en>After eating the apple,</en>
    </text>
    <text duration="3">
      <ja>ふかい ねむりに おちてしまいました。</ja>
      <en>Snow White fell into a deep sleep.</en>
    </text>
    <image>scene5.png</image>
  </page>
  <page>
    <text duration="3">
      <ja>おうじさまの キスで しらゆきひめは めを さまし、</ja>
      <en>A prince's kiss awakened Snow White,</en>
    </text>
    <text duration="2">
      <ja>ふたりは しあわせに くらしました。</ja>
      <en>and they lived happily ever after.</en>
    </text>
    <image>scene6.png</image>
  </page>

  <questions>
    <question duration="6" answer_duration="3">
      <text>
        <ja>しらゆきひめの はだは なにのように しろかったですか？</ja>
        <en>What was Snow White's skin as white as?</en>
      </text>
      <image>scene1.png</image>
      <choices>
        <choice>
          <ja>もも</ja>
          <en>Peach</en>
        </choice>
        <choice>
          <ja>はな</ja>
          <en>Flower</en>
        </choice>
        <choice correct="true">
          <ja>ゆき</ja>
          <en>Snow</en>
        </choice>
      </choices>
    </question>
    <question duration="6" answer_duration="3">
      <text>
        <ja>じょおうは なにを もっていましたか？</ja>
        <en>What did the evil queen have?</en>
      </text>
      <image>scene2.png</image>
      <choices>
        <choice correct="true">
          <ja>まほうのかがみ</ja>
          <en>Magic mirror</en>
        </choice>
        <choice>
          <ja>まほうのつえ</ja>
          <en>Magic wand</en>
        </choice>
        <choice>
          <ja>まほうのほうき</ja>
          <en>Magic broom</en>
        </choice>
      </choices>
    </question>
    <question duration="6" answer_duration="3">
      <text>
        <ja>しらゆきひめは もりで だれの いえに かくれましたか？</ja>
        <en>Whose house did Snow White hide in the forest?</en>
      </text>
      <image>scene3.png</image>
      <choices>
        <choice>
          <ja>おうじさまの いえ</ja>
          <en>The prince's house</en>
        </choice>
        <choice correct="true">
          <ja>こびとたちの いえ</ja>
          <en>The dwarfs' cottage</en>
        </choice>
        <choice>
          <ja>まほうつかいの いえ</ja>
          <en>The witch's house</en>
        </choice>
      </choices>
    </question>
    <question duration="6" answer_duration="3">
      <text>
        <ja>じょおうは しらゆきひめに なにを たべさせましたか？</ja>
        <en>What did the queen give Snow White to eat?</en>
      </text>
      <image>scene4.png</image>
      <choices>
        <choice>
          <ja>どくの もも</ja>
          <en>Poisoned peach</en>
        </choice>
        <choice correct="true">
          <ja>どくの りんご</ja>
          <en>Poisoned apple</en>
        </choice>
        <choice>
          <ja>どくの なし</ja>
          <en>Poisoned pear</en>
        </choice>
      </choices>
    </question>
    <question duration="6" answer_duration="3">
      <text>
        <ja>しらゆきひめを めざめさせたのは だれですか？</ja>
        <en>Who awakened Snow White?</en>
      </text>
      <image>scene6.png</image>
      <choices>
        <choice>
          <ja>こびとたち</ja>
          <en>The dwarfs</en>
        </choice>
        <choice>
          <ja>まほうつかい</ja>
          <en>A fairy godmother</en>
        </choice>
        <choice correct="true">
          <ja>おうじさま</ja>
          <en>The prince</en>
        </choice>
      </choices>
    </question>
  </questions>
</ehon>
